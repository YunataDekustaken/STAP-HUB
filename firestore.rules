rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Since this is a custom client configuration, we trust the authenticating email from their domain or standard Google Account.
    // If you want to lock it down to specific email domains (e.g., admin@stap.gov) in your own Firebase project, 
    // update this helper to check request.auth.token.email.endsWith('@stap.gov') or matches specific admins.
    function isOperator() {
      return isSignedIn() && (
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. TRAFFIC HISTORICAL LOGS
    match /traffic_logs/{logId} {
      allow read: if true; // Public access to charts and dashboards
      allow write: if isOperator() && isValidId(logId);
    }

    // 2. PUBLIC FOOTAGE REQUESTS
    match /footage_requests/{requestId} {
      allow create: if true; // Public citizens can submit requests
      allow read: if true;   // Public can view status or searchable ID track
      allow update, delete: if isOperator() && isValidId(requestId);
    }

    // 3. INCIDENT REPORTS
    match /incident_reports/{reportId} {
      allow create: if true; // Public can report incidents
      allow read: if true;   // Public dashboard needs to render incidents
      allow update, delete: if isOperator() && isValidId(reportId);
    }

    // 4. ANNOUNCEMENTS
    match /announcements/{announcementId} {
      allow read: if true; // Anyone can read advisories
      allow write: if isOperator() && isValidId(announcementId);
    }

    // 5. SYSTEM USERS (Allow operators to read and manage users to avoid complex get lookup dependencies)
    match /users/{userId} {
      allow read, write: if isOperator();
    }

    // 6. SYSTEM SETTINGS
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isOperator() || isSignedIn();
    }
  }
}
